# /opt/wallchart26/wallchart26.env  — SECRETS ONLY, chmod 600, do NOT commit.
# Non-secret config (ADDR, DATABASE_PATH, COOKIE_SECURE, ...) lives in the systemd unit.
# Fill these from your local .env:  grep -E 'ADMIN_EMAILS|SMTP_' .env

ADMIN_EMAILS=you@example.com
# Stages closed for predictions (comma-separated, exact names). Remove a stage to
# open it; opening a knockout stage emails subscribers that it's available.
# Valid: Round of 32, Round of 16, Quarter-final, Semi-final, Third place, Final
# IMPORTANT: keep LOCK_STAGES present (even empty) for the whole tournament. The
# "stage is open" emails are sent ONLY when LOCK_STAGES is set; if it is absent,
# every stage counts as open and the announcements are suppressed to avoid spam.
LOCK_STAGES="Round of 16,Quarter-final,Semi-final,Third place,Final"
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxx
SMTP_FROM="Wallchart '26 <login@wallchart26.com>"
