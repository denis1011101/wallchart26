# /opt/wallchart26/wallchart26.env  — SECRETS ONLY, chmod 600, do NOT commit.
# Non-secret config (ADDR, DATABASE_PATH, COOKIE_SECURE, ...) lives in the systemd unit.
# Fill these from your local .env:  grep -E 'ADMIN_EMAILS|SMTP_' .env

ADMIN_EMAILS=you@example.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxx
SMTP_FROM="Wallchart '26 <login@wallchart26.com>"
