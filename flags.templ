package main

// Flag renders a small square country flag for a team key (nothing for
// placeholders / unknown teams), followed by any children — typically the
// localized team name.
templ Flag(key string) {
	if iso := teamFlagISO(key); iso != "" {
		<img class="flag" src={ "/static/flags/" + iso + ".svg" } alt="" width="18" height="18" loading="lazy"/>
	}
	{ children... }
}
